{
  "name": "@domain-explorer/init",
  "version": "0.1.0",
  "private": true,
  "description": "Customer Accelerator CLI — produce a branded clone of Domain Explorer in 30 seconds.",
  "type": "module",
  "bin": {
    "domain-explorer-init": "./bin/init.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./steps/*": "./src/steps/*.js",
    "./utils/*": "./src/utils/*.js"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/init.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
