# Domain Explorer environment variables.
# Copy to .env (or .env.local for the Next.js app) and fill in values you need.

# --- LLM providers (any combination — the assistant routes through a
# vendor-agnostic abstraction with automatic failover) -----------------------

# Anthropic API key — enables live Claude responses on the /assistant route.
# Without any provider key the assistant streams from canned-answers.json
# (50 entries) so the demo still works out of the box.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (GPT-4 / GPT-4o). Used when ANTHROPIC fails over or first in chain
# if you put it ahead of anthropic in LLM_PROVIDERS.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini.
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# LiteLLM proxy. When set, the assistant routes ALL traffic through the
# proxy URL — that lets you swap models without touching app config. The
# proxy must expose an OpenAI-compatible /v1/chat/completions endpoint.
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=claude-sonnet-4-6

# Comma-separated provider order. Default keeps backwards-compat with the
# original Claude-only setup ("anthropic,mock" — `mock` is the always-available
# safety net so the demo never breaks). Add `openai` and/or `google` to
# include them in the failover chain. `litellm` is prepended automatically
# whenever LITELLM_BASE_URL is set.
LLM_PROVIDERS=anthropic,mock
