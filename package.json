{
  "name": "domain-explorer",
  "version": "0.1.0",
  "private": true,
  "description": "Metadata-driven explorer for industry verticals, subdomains, KPIs, and integration patterns.",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter explorer-web dev",
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "lint": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "typecheck": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" typecheck",
    "test": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" test",
    "dbt:deps": "cd modeling/dbt && DBT_PROFILES_DIR=. dbt deps",
    "dbt:build": "cd modeling/dbt && DBT_PROFILES_DIR=. dbt deps && DBT_PROFILES_DIR=. dbt run --select payments